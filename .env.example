# Amadeus Self-Service API credentials — get them free at:
# https://developers.amadeus.com/  (Create app -> copy Key & Secret)
AMADEUS_CLIENT_ID=your_api_key_here
AMADEUS_CLIENT_SECRET=your_api_secret_here

# Optional: Telegram notifications (set notify.telegram.enabled=true in config.json)
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# TELEGRAM_CHAT_ID=123456789
